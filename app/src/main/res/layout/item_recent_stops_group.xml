<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/eink_card_background"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="2dp"
    android:weightSum="3">

    <!-- First stop -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/firstStopContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/firstStopIdText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EInkText.Large"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/firstStopNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EInkText.Small"
                android:gravity="center"
                android:minHeight="64dp"
                android:maxLines="4"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/firstDeleteButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:src="@drawable/close_24px"
            android:background="@drawable/eink_button_background"
            android:visibility="gone"
            android:contentDescription="@string/delete_stop" />
    </FrameLayout>

    <!-- Vertical separator -->
    <View
        android:id="@+id/firstSeparator"
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="?attr/appOnBackground"
        android:layout_marginVertical="12dp" />

    <!-- Second stop -->
    <FrameLayout
        android:id="@+id/secondStopFrame"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/secondStopContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/secondStopIdText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EInkText.Large"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/secondStopNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EInkText.Small"
                android:gravity="center"
                android:minHeight="64dp"
                android:maxLines="4"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/secondDeleteButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:src="@drawable/close_24px"
            android:background="@drawable/eink_button_background"
            android:visibility="gone"
            android:contentDescription="@string/delete_stop" />
    </FrameLayout>

    <!-- Vertical separator -->
    <View
        android:id="@+id/secondSeparator"
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="?attr/appOnBackground"
        android:layout_marginVertical="12dp"
        android:visibility="gone"/>

    <!-- Third stop -->
    <FrameLayout
        android:id="@+id/thirdStopFrame"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/thirdStopContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/thirdStopIdText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EInkText.Large"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/thirdStopNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EInkText.Small"
                android:gravity="center"
                android:minHeight="64dp"
                android:maxLines="4"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/thirdDeleteButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:src="@drawable/close_24px"
            android:background="@drawable/eink_button_background"
            android:visibility="gone"
            android:contentDescription="@string/delete_stop" />
    </FrameLayout>

</LinearLayout>