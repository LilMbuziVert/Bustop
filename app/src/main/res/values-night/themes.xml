<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark mode app theme -->
    <style name="Theme.Bustop" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Pure black background with off-white text -->
        <item name="appBackground">#000000</item>
        <item name="appOnBackground">@color/eink_off_white</item>
        <item name="appOnSurface">@color/eink_medium_gray</item>
        <item name="appErrorColor">@color/eink_accent_red</item>
        <item name="appScrollbarColor">@color/eink_medium_gray</item>
        <item name="delayLateColor">#FF6B6B</item> <!-- Lighter red for dark mode -->
        <item name="delayEarlyColor">#4ECDC4</item> <!-- Lighter green for dark mode -->

        <!-- Status bar configuration -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>